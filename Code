        cin>>more;
    }while(more=='y'|| more=='Y');
     cout << "\nTotal Bill: Rs. "
         << totalbill << endl;
    return totalbill;
}

// this is the service charge function
double calculateservicecharge(double totalbill,int ordertype){

    if(ordertype==1){
   	return totalbill*0.10;
   }else{
   	return totalbill*0.05;
   }
}
double calculategst(double totalbill){
	return totalbill*0.16;
}
double calculatediscount(double totalbill){
	if (totalbill>=3000 && totalbill <= 5000){
		return totalbill * 0.05;
	} else if (totalbill>5000 && totalbill<=10000){
		return totalbill * 0.10;
	} else if(totalbill >10000){
		return totalbill*0.15;
	}
	return 0;
}

// this is the Final bill function
void displayfinalbill(double totalbill, int ordertype, string name, int person,string &contactnumber)
{
    double servicecharge = calculateservicecharge(totalbill, ordertype);
    double gst = calculategst(totalbill);
    double discount = calculatediscount(totalbill);

    double Finalbill = totalbill + servicecharge + gst - discount;

    cout << "\n========== RESTAURANT BILL ==========\n\n";
    cout << "Customer Name: " << name << endl;
    cout <<" Contact Number:"<<contactnumber<<endl;
    if(ordertype == 1){
    	cout << "Order Type: Dine-in" << endl;
	} else {
		cout << "Order Type: Takeaway" << endl;
	}  
    cout << "Number of Persons: " << person << endl;
    cout << "\nFood Bill: Rs. " << totalbill << endl;
    cout << "Service Charges: Rs. " << servicecharge << endl;
    cout << "GST: Rs. " << gst << endl;
    cout << "Discount: Rs. " << discount << endl;
    cout << "\n------------------------------------\n";
    cout << "Total Payable Amount: Rs. " << Finalbill << endl;
    cout << "Enjoy Your Meal :" << endl;
    cout << "====================================\n";
}
